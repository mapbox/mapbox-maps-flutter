{
    "version": 8,
    "name": "Minimal Land & Sea (transparent space)",
    "projection": {
        "name": "globe"
    },
    "sources": {
        "composite": {
            "type": "vector",
            "url": "mapbox://mapbox.mapbox-streets-v8"
        },
        "world": {
            "type": "geojson",
            "data": {
                "type": "Feature",
                "geometry": {
                    "type": "Polygon",
                    "coordinates": [
                        [
                            [-180, -85],
                            [180, -85],
                            [180, 85],
                            [-180, 85],
                            [-180, -85]
                        ]
                    ]
                }
            }
        }
    },
    "fog": {
        "range": [
            0.5,
            10
        ],
        "color": "rgba(0, 0, 0, 0)",
        "high-color": "rgba(0, 0, 0, 0)",
        "space-color": "rgba(0, 0, 0, 0)",
        "horizon-blend": 0,
        "star-intensity": 0
    },
    "layers": [
        {
            "id": "continents",
            "type": "fill",
            "source": "world",
            "paint": {
                "fill-color": "#e6ddc9",
                "fill-opacity": 1
            }
        },
        {
            "id": "seas",
            "type": "fill",
            "source": "composite",
            "source-layer": "water",
            "paint": {
                "fill-color": "#8fb8d6",
                "fill-opacity": 1
            }
        }
    ]
}
